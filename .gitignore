# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/

# --- uv ---
.uv/
uv.lock

# --- Secrets / config ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Data / artifacts (do NOT commit) ---
*.lmdb
*.lmdb-lock
*.db
*.sqlite
data/
models/
checkpoints/
.cache/

# Test fixtures: keep small_bill.pdf, ignore large bills
tests/fixtures/big_beautiful_bill.pdf
tests/fixtures/*.pdf
!tests/fixtures/small_bill.pdf
!tests/fixtures/.gitkeep

# Eval outputs
eval/result_*.json
eval/golden_findings.json

# Canonical reports (the JSON snapshots that drive the Bills Lookup gallery)
# are committed — these are small (<2 MB total) and required for the demo to
# light up without re-running the full agent pipeline.
!eval/canonical/
!eval/canonical/*.json

# Generated cloud-podcast assets (slides, wan clips, tts, master mp4) are
# regenerable from the canonical reports + scripts/make_podcast_cloud.py and
# would otherwise add ~30+ MB per bill to the repo.
eval/*-cloud/
eval/*-cloud-custom-*/

# Historical experiment outputs (Day 6 / Day 7 R&D scratch runs)
eval/day6-*/
eval/day7-*/
eval/day7-*.json
eval/day7-*.mp4
eval/podcast-*-tmp/
eval/podcast-*.mp3
eval/podcast-*.mp4

# Block all binary media from accidental commits anywhere under eval/
eval/**/*.mp4
eval/**/*.mp3
eval/**/*.wav
eval/**/*.flac
eval/**/*.png
eval/**/*.jpg
eval/**/*.jpeg
eval/**/*.webp

!eval/.gitkeep

# --- IDE / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / telemetry ---
*.log
logs/
telemetry/

# --- Notebooks ---
.ipynb_checkpoints/

# --- ROCm / vLLM scratch ---
.vllm_cache/
.hf_cache/

# Qwen TTS render scratch
eval/*-qwen-tts-tmp/

